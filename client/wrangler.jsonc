{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Must match the Worker name in your Cloudflare dashboard.
  "name": "holos",
  "compatibility_date": "2025-01-01",
  // Static-assets-only Worker (no `main`): serves the Vite build in ./dist.
  // `single-page-application` serves index.html for unknown paths so client
  // routing keeps working on refresh.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
